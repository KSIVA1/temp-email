---
import Layout from '~/layouts/Layout.astro';
import Header from '~/components/Header.astro';

const lastUpdated = '2026-05-23';
const lastUpdatedDisplay = 'May 23, 2026';

const faqs = [
  {
    q: 'Can I use InboxForNow to evade an account ban or platform rule?',
    a: 'No. Creating ban-evasion accounts or signing up where a platform explicitly prohibits disposable email is against our terms and against the destination platform\'s terms. Use a temporary address for legitimate privacy reasons only.',
  },
  {
    q: 'Can I send email through InboxForNow?',
    a: 'No. The service is receive-only by design. There is no outbound SMTP, no reply path, and no relay. Attempting to abuse the platform for outbound mail will result in inbox deletion.',
  },
  {
    q: 'What happens if a receiving domain stops working?',
    a: 'Receiving domains rotate as platforms blacklist them. If your verification email doesn\'t arrive, generate a new address — it will likely pull from a different domain in the active pool.',
  },
  {
    q: 'Is there a guarantee that an inbox will receive mail?',
    a: 'No. Platforms may block our receiving domains, mail servers may drop messages, and infrastructure can fail. Treat InboxForNow as a best-effort utility — use a real email for accounts you cannot afford to lose access to.',
  },
  {
    q: 'Can I rely on receiving password-reset emails after the inbox expires?',
    a: 'No. The inbox is hard-deleted when the timer ends, so any later mail sent to that address bounces. If long-term recovery matters, copy your credentials before the timer ends or use a real email.',
  },
];

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---
<Layout
  title="Terms of Service — InboxForNow"
  description="Terms for using InboxForNow: receive-only inboxes, no fraud or harassment, no warranty. Read before using the temporary email service."
  additionalJsonLd={[faqJsonLd]}
>
  <Header />
  <main class="legal">
    <article class="legal__body">
      <p class="label"><span class="label__dot" aria-hidden="true"></span>Terms</p>
      <h1>Terms of Service</h1>
      <p class="legal__meta">Last updated <time datetime={lastUpdated}>{lastUpdatedDisplay}</time></p>
      <p>InboxForNow is a temporary, receive-only email utility. You may use it to receive verification emails, magic links, and similar low-risk messages.</p>
      <h2>Receive-only architecture</h2>
      <p>The service does not provide outbound email. You cannot send, reply to, relay, or impersonate mail through InboxForNow.</p>
      <h2>Prohibited use</h2>
      <p>Do not use InboxForNow for fraud, harassment, credential theft, spam, illegal activity, or attempts to evade platform rules where temporary email is not allowed.</p>
      <h2>No warranty</h2>
      <p>The service is provided as-is. Inboxes may expire, be deleted, fail to receive a message, or be blocked by third-party platforms without notice.</p>
      <h2>Abuse handling</h2>
      <p>We may reject inbound messages, disable receiving domains, or delete inboxes when needed to protect users, platforms, or infrastructure.</p>
      <h2>Jurisdiction</h2>
      <p>These terms are governed by the laws applicable to the service operator's place of business, without regard to conflict-of-law rules.</p>

      <section class="legal__faq" aria-labelledby="terms-faq-heading">
        <h2 id="terms-faq-heading">Terms FAQ</h2>
        {faqs.map((f) => (
          <details class="legal__faq__item">
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </section>
    </article>
  </main>
</Layout>

<style>
  .legal { padding: clamp(2rem, 1.2rem + 3vw, 4rem) clamp(1rem, 0.5rem + 2vw, 2.2rem); }
  .legal__body { max-width: 760px; margin: 0 auto; color: var(--text); }
  .legal__body h1 { font-size: var(--fs-h1); margin: var(--sp-2) 0 var(--sp-3); }
  .legal__body h2 { font-size: 1rem; margin: var(--sp-6) 0 var(--sp-2); }
  .legal__body p { color: var(--text-2); line-height: 1.65; }
  .legal__meta {
    color: var(--text-3);
    font-size: var(--fs-small);
    margin: 0 0 var(--sp-5);
  }
  .legal__faq {
    margin-top: var(--sp-8);
    padding-top: var(--sp-6);
    border-top: 1px solid var(--border);
  }
  .legal__faq h2 { margin-top: 0; font-size: var(--fs-h3); }
  .legal__faq__item {
    border: 1px solid var(--border);
    border-radius: var(--r-md);
    padding: 0;
    margin: var(--sp-2) 0;
    background: var(--surface);
  }
  .legal__faq__item summary {
    cursor: pointer;
    padding: var(--sp-3) var(--sp-4);
    font-weight: 500;
    color: var(--text);
    list-style: none;
    font-size: var(--fs-small);
  }
  .legal__faq__item summary::-webkit-details-marker { display: none; }
  .legal__faq__item[open] summary { border-bottom: 1px solid var(--border); }
  .legal__faq__item p {
    padding: var(--sp-3) var(--sp-4);
    margin: 0;
    font-size: var(--fs-small);
    line-height: 1.6;
  }
</style>
