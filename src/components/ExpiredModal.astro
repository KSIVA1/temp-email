---
// Auto-opens when the inbox timer hits 00:00. Single decision:
// "Get new address" instantly spins up a fresh inbox. Dismissible
// via Esc, backdrop click, or the X button — returning the user
// to the expired card state if they want to copy the dead address
// or extend something they were doing.
---
<div
  id="expired-modal"
  class="xm"
  role="dialog"
  aria-modal="true"
  aria-labelledby="xm-title"
  aria-hidden="true"
>
  <div class="xm__backdrop" data-xm-dismiss aria-hidden="true"></div>

  <div class="xm__panel" role="document">
    <button
      class="xm__close"
      type="button"
      data-xm-dismiss
      aria-label="Dismiss"
    >
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path d="M18 6 6 18M6 6l12 12" stroke-linecap="round"/>
      </svg>
    </button>

    <span class="xm__eyebrow">
      <span class="xm__eyebrow-dot" aria-hidden="true"></span>
      Expired
    </span>

    <h2 id="xm-title" class="xm__title">This inbox expired.</h2>
    <p class="xm__sub">Spin up a fresh one and keep moving.</p>

    <button
      id="xm-action"
      class="btn btn--primary xm__action"
      type="button"
    >
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path d="M21 12a9 9 0 1 1-3.51-7.13M21 4v5h-5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      Get new address
    </button>
  </div>
</div>

<style>
  .xm {
    position: fixed;
    inset: 0;
    z-index: 320;
    display: grid;
    place-items: center;
    padding: var(--sp-4);
    pointer-events: none;
    visibility: hidden;
  }
  .xm[aria-hidden="false"] {
    pointer-events: auto;
    visibility: visible;
  }

  .xm__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(9, 9, 11, 0);
    transition: background-color .25s var(--ease-out);
    cursor: pointer;
  }
  .xm[aria-hidden="false"] .xm__backdrop {
    background: rgba(9, 9, 11, 0.5);
  }
  :root[data-theme="dark"] .xm[aria-hidden="false"] .xm__backdrop {
    background: rgba(0, 0, 0, 0.7);
  }

  .xm__panel {
    position: relative;
    width: min(360px, 100%);
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--r-lg);
    box-shadow: var(--shadow-4);
    padding: var(--sp-5);
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
    opacity: 0;
    transform: translateY(8px) scale(0.98);
    transition: opacity .22s var(--ease-out), transform .22s var(--ease-out);
  }
  .xm[aria-hidden="false"] .xm__panel {
    opacity: 1;
    transform: translateY(0) scale(1);
  }

  .xm__close {
    position: absolute;
    top: 0.6rem;
    right: 0.6rem;
    appearance: none;
    background: transparent;
    border: 1px solid transparent;
    color: var(--text-3);
    width: 30px;
    height: 30px;
    border-radius: var(--r-sm);
    cursor: pointer;
    display: grid;
    place-items: center;
    transition: color .15s ease, background-color .15s ease, border-color .15s ease;
  }
  .xm__close:hover {
    color: var(--text);
    background: var(--surface-2);
    border-color: var(--border);
  }
  .xm__close:focus-visible {
    outline: 2px solid var(--data);
    outline-offset: 2px;
  }

  .xm__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: var(--fs-small);
    font-weight: 600;
    color: var(--danger);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .xm__eyebrow-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--danger);
  }

  .xm__title {
    font-size: 1.375rem;
    font-weight: 600;
    color: var(--text);
    margin: 0;
    letter-spacing: -0.02em;
    line-height: 1.2;
  }

  .xm__sub {
    color: var(--text-2);
    margin: 0;
    line-height: 1.5;
  }

  .xm__action {
    margin-top: var(--sp-2);
    align-self: stretch;
    height: 44px;
    gap: 0.5rem;
  }
</style>
