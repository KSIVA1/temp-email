---
// Onboarding tour scaffold — JS in app.ts measures anchors, positions the
// spotlight + panel, and swaps title/body per step.
---
<div id="tour" class="tour" aria-hidden="true" role="dialog">
  <div class="tour__backdrop" data-tour-skip></div>
  <div class="tour__spotlight" id="tour-spotlight"></div>
  <div class="tour__panel" id="tour-panel" role="dialog" aria-modal="true" aria-labelledby="tour-title">
    <div class="tour__top">
      <div class="tour__steps" id="tour-steps" aria-hidden="true">
        <span></span><span></span><span></span>
      </div>
      <button class="tour__close" type="button" data-tour-skip aria-label="Skip tour">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true">
          <path d="M6 6l12 12M18 6L6 18" stroke-linecap="round"/>
        </svg>
      </button>
    </div>
    <h3 class="tour__title" id="tour-title"></h3>
    <p class="tour__body" id="tour-body"></p>
    <div class="tour__actions">
      <button class="btn btn--tiny btn--ghost" type="button" data-tour-prev id="tour-prev">
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="m15 6-6 6 6 6" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        Back
      </button>
      <div class="tour__spacer"></div>
      <button class="tour__skip-link" type="button" data-tour-skip id="tour-skip">Skip tour</button>
      <button class="btn btn--tiny btn--primary" type="button" data-tour-next id="tour-next">
        Next
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="m9 6 6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    </div>
  </div>
</div>
