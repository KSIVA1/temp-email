---
// Clean card with a tight hierarchy:
//   eyebrow label · big tight headline · supporting line ·
//   the address (mono, surface-2 background, primary copy button inline) ·
//   timer + extension row · safety notes
//
// Hero block (kicker/heading/sub) is overridable so use-case pages can
// supply platform-specific copy without duplicating the form card. Setting
// hideHero={true} skips the marketing hero entirely (use-case pages
// supply their own H1 above this component).

interface Props {
  kicker?: string;
  heading?: string;
  sub?: string;
  hideHero?: boolean;
}

const {
  kicker  = 'Disposable inbox · live',
  heading = 'A throwaway inbox,<br/>ready in zero clicks.',
  sub     = 'Use this address to receive verification codes, magic links and newsletter sign-ups. Hard-deleted when the timer runs out.',
  hideHero = false,
} = Astro.props;

const turnstileSiteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY;
---
<section class="address" aria-labelledby="address-heading">
  {!hideHero && (
    <>
      <span class="label">
        <span class="label__dot" aria-hidden="true"></span>
        {kicker}
      </span>

      <h1 id="address-heading" class="address__h" set:html={heading} />

      <p class="address__sub">{sub}</p>
    </>
  )}

  <div class="address__field card" role="group" aria-label="Your temporary email address" data-tour="address">
    <div class="address__row">
      <div class="address__value-wrap">
        <span class="label address__field-label">Your address</span>
        <div class="address__value">
          <span id="addr-local"  class="address__local">fox9821</span><span class="address__at" aria-hidden="true">@</span><span id="addr-domain" class="address__domain">veqla.com</span>
        </div>
      </div>

      <button id="copy-btn" class="btn btn--primary address__copy" type="button" aria-label="Copy address to clipboard">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <rect x="9" y="9" width="11" height="11" rx="2"/>
          <path d="M5 15V6a2 2 0 0 1 2-2h9" stroke-linecap="round"/>
        </svg>
        <span class="address__copy-label">Copy</span>
      </button>
    </div>

    <div class="address__actions">
      <button id="refresh-btn" class="btn btn--ghost btn--tiny" type="button" aria-label="Generate a new address">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M21 12a9 9 0 1 1-3.51-7.13M21 4v5h-5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        New address
      </button>

      <button id="qr-btn" class="btn btn--ghost btn--tiny" type="button" aria-expanded="false" aria-controls="qr-panel">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <rect x="3" y="3" width="7" height="7" rx="1"/>
          <rect x="14" y="3" width="7" height="7" rx="1"/>
          <rect x="3" y="14" width="7" height="7" rx="1"/>
          <path d="M14 14h3v3h-3zM20 14v3M14 20h3v1h-3zM18 18h3v3" stroke-linecap="round"/>
        </svg>
        QR
      </button>

      <div class="address__spacer"></div>

      <div class="address__timer-inline" aria-live="polite" data-tour="timer">
        <span class="address__timer-label">Expires</span>
        <span class="address__clock" id="timer-clock">
          <span id="timer-mm" class="address__clock-n">09</span><span class="address__clock-c">:</span><span id="timer-ss" class="address__clock-n">58</span>
        </span>
      </div>
    </div>

    <div id="qr-panel" class="address__qr" hidden>
      <div id="qr-canvas" class="address__qr-canvas" aria-hidden="true"></div>
      <p class="address__qr-caption">
        Scan from another device. The address is the same — useful when you're
        registering on your phone but watching the inbox on a laptop.
      </p>
    </div>
  </div>

  <div class="address__controls">
    <span class="label address__controls-label">Extend</span>
    <div class="address__extend">
      <button class="btn btn--tiny btn--ghost" type="button" data-extend="600">+ 10 min</button>
      <button class="btn btn--tiny btn--ghost" type="button" data-extend="3600">+ 1 hour</button>
      <button class="btn btn--tiny btn--ghost" type="button" data-extend="86400">+ 24 hours</button>
    </div>
    <button class="btn btn--tiny btn--danger-ghost" type="button" id="burn-btn" aria-label="Destroy this inbox now">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path d="M3 6h18M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      Delete now
    </button>
  </div>

  {turnstileSiteKey && (
    <div id="turnstile-widget" class="turnstile-hidden" data-sitekey={turnstileSiteKey}></div>
  )}

  <ul class="address__notes" aria-label="Promises">
    <li>
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path d="M20 6 9 17l-5-5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      <span><strong>Receive-only.</strong> No outbound sending, ever.</span>
    </li>
    <li>
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path d="M20 6 9 17l-5-5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      <span><strong>HTML sanitized.</strong> Scripts and tracking pixels are stripped before the message lands.</span>
    </li>
    <li>
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path d="M20 6 9 17l-5-5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      <span><strong>Hard-deleted</strong> when the timer ends. Not archived. Not logged.</span>
    </li>
  </ul>

  {/* History — populated by app.ts when there is at least one entry */}
  <section id="history" class="history" hidden></section>
</section>

<style>
  .address {
    display: flex;
    flex-direction: column;
    gap: var(--sp-5);
  }

  .turnstile-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    white-space: nowrap;
  }

  .address__h {
    font-size: var(--fs-h1);
    margin-top: var(--sp-2);
    color: var(--text);
  }

  .address__sub {
    color: var(--text-2);
    font-size: var(--fs-lead);
    max-width: 48ch;
    margin: -0.25rem 0 0;
    line-height: 1.5;
  }

  /* The card containing the address + actions */
  .address__field {
    padding: var(--sp-5);
    display: flex;
    flex-direction: column;
    gap: var(--sp-4);
  }

  .address__row {
    display: flex;
    gap: var(--sp-3);
    align-items: stretch;
  }

  .address__value-wrap {
    flex: 1 1 auto;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: var(--r-md);
    padding: 0.7rem 0.85rem;
  }

  .address__field-label {
    color: var(--text-3);
  }

  .address__value {
    font-family: var(--ff-mono);
    font-size: var(--fs-mono);
    font-weight: 500;
    color: var(--text);
    letter-spacing: -0.02em;
    line-height: 1.2;
    user-select: all;
    overflow-wrap: anywhere;
    display: inline;
  }
  .address__at { color: var(--data); padding: 0 0.02em; }
  .address__domain { color: var(--text-2); }

  .address__copy {
    align-self: stretch;
    height: auto;
    padding: 0 var(--sp-4);
    flex-shrink: 0;
  }

  @media (max-width: 480px) {
    .address__row { flex-direction: column; }
    .address__copy { align-self: stretch; height: 40px; }
    .address__copy-label { font-size: var(--fs-small); }
  }

  .address__actions {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  .address__spacer { flex: 1 1 0; min-width: 0; }

  .address__timer-inline {
    display: inline-flex;
    align-items: baseline;
    gap: 0.55rem;
    padding: 0.3rem 0.65rem;
    background: var(--danger-soft);
    border: 1px solid color-mix(in srgb, var(--danger) 35%, transparent);
    border-radius: var(--r-sm);
  }

  .address__timer-label {
    font-size: var(--fs-small);
    font-weight: 600;
    color: var(--danger);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .address__clock {
    font-family: var(--ff-mono);
    font-size: 1.125rem;
    font-weight: 600;
    font-feature-settings: "tnum" 1;
    color: var(--danger);
    display: inline-flex;
    align-items: baseline;
    letter-spacing: -0.01em;
    line-height: 1;
  }
  .address__clock-n {
    display: inline-block;
    min-width: 2ch;
    text-align: center;
  }
  .address__clock-c {
    animation: blink 1s steps(2) infinite;
    padding: 0 0.05em;
    color: var(--danger);
    opacity: 0.7;
  }
  @keyframes blink { 50% { opacity: 0.2; } }

  /* QR */
  .address__qr[hidden] { display: none !important; }
  .address__qr {
    display: flex;
    gap: var(--sp-4);
    align-items: center;
    padding-top: var(--sp-4);
    border-top: 1px solid var(--border);
    animation: dropIn .25s var(--ease-out);
  }
  @keyframes dropIn {
    from { opacity: 0; transform: translateY(-4px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .address__qr-canvas {
    width: 96px;
    height: 96px;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: var(--r-sm);
    padding: 6px;
    flex-shrink: 0;
    display: grid;
    place-items: center;
  }
  .address__qr-canvas svg {
    width: 100%;
    height: 100%;
    color: var(--text);
  }
  .address__qr-caption {
    color: var(--text-2);
    font-size: var(--fs-small);
    margin: 0;
    line-height: 1.45;
  }

  /* Extension/burn row outside the card */
  .address__controls {
    display: flex;
    align-items: center;
    gap: var(--sp-3);
    flex-wrap: wrap;
  }
  .address__controls-label {
    color: var(--text-3);
  }
  .address__extend {
    display: inline-flex;
    gap: 0.3rem;
    flex-wrap: wrap;
  }

  /* Promises */
  .address__notes {
    list-style: none;
    padding: 0;
    margin: var(--sp-2) 0 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    font-size: var(--fs-small);
    color: var(--text-2);
  }
  .address__notes li {
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
    line-height: 1.45;
  }
  .address__notes svg {
    color: var(--data);
    flex-shrink: 0;
    margin-top: 0.2rem;
  }
  .address__notes strong {
    color: var(--text);
    font-weight: 500;
  }

  /* Recently used addresses */
  .history {
    margin-top: var(--sp-5);
    padding-top: var(--sp-5);
    border-top: 1px solid var(--border);
    display: block;
  }
  .history[hidden] { display: none; }

  .history__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--sp-3);
  }
  .history__clear {
    appearance: none;
    background: transparent;
    border: 0;
    color: var(--text-3);
    font-family: var(--ff-sans);
    font-size: var(--fs-micro);
    cursor: pointer;
    padding: 0.25rem 0.4rem;
    border-radius: var(--r-xs);
    transition: color .15s ease, background-color .15s ease;
  }
  .history__clear:hover {
    color: var(--text);
    background: var(--surface-2);
  }

  .history__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }
  .history__item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-3);
    padding: 0.55rem 0.7rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--r-md);
    transition: border-color .15s ease, background-color .15s ease;
  }
  .history__item:hover {
    border-color: var(--border-strong);
    background: var(--surface-2);
  }
  .history__main {
    display: flex;
    flex-direction: column;
    gap: 0.05rem;
    min-width: 0;
    flex: 1 1 auto;
  }
  .history__addr {
    font-family: var(--ff-mono);
    font-size: 0.8125rem;
    color: var(--text-2);
    font-weight: 500;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .history__when {
    font-size: 0.7rem;
    color: var(--text-3);
  }
  .history__actions {
    display: inline-flex;
    gap: 0.25rem;
    flex-shrink: 0;
  }
  .history__remove {
    appearance: none;
    background: transparent;
    border: 1px solid transparent;
    color: var(--text-3);
    cursor: pointer;
    width: 28px;
    height: 28px;
    border-radius: var(--r-sm);
    display: grid;
    place-items: center;
    transition: color .15s ease, background-color .15s ease, border-color .15s ease;
  }
  .history__remove:hover {
    color: var(--danger);
    background: var(--danger-soft);
    border-color: color-mix(in srgb, var(--danger) 30%, transparent);
  }
</style>
