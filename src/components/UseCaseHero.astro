---
import type { Platform } from '~/data/platforms';
import { CATEGORIES } from '~/data/platforms';

interface Props { platform: Platform; }
const { platform } = Astro.props;
const cat = CATEGORIES[platform.category];
---
<header class="uc-hero">
  <div class="uc-hero__top">
    <span class="uc-hero__icon" aria-hidden="true">{platform.initials}</span>
    <div class="uc-hero__meta">
      <span class="uc-hero__category">{cat.label}</span>
      <span class="uc-hero__separator">·</span>
      <span class="uc-hero__type">
        {platform.verificationType === 'code' ? 'Verification code' :
         platform.verificationType === 'link' ? 'Magic link' :
         'Code or link'} · arrives in {platform.typicalWaitTime}
      </span>
    </div>
  </div>

  <h1 class="uc-hero__h">Temporary email for {platform.name}</h1>
  <p class="uc-hero__sub">{platform.oneLiner} {platform.privacyAngle}</p>
</header>

<style>
  .uc-hero {
    display: flex;
    flex-direction: column;
    gap: var(--sp-4);
    padding-bottom: var(--sp-7);
    border-bottom: 1px solid var(--border);
    margin-bottom: var(--sp-8);
  }

  .uc-hero__top {
    display: flex;
    align-items: center;
    gap: var(--sp-3);
  }

  .uc-hero__icon {
    width: 44px;
    height: 44px;
    border-radius: var(--r-md);
    background: var(--surface-2);
    border: 1px solid var(--border);
    color: var(--text);
    font-weight: 600;
    font-size: 0.95rem;
    letter-spacing: 0.02em;
    display: grid;
    place-items: center;
    flex-shrink: 0;
  }

  .uc-hero__meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    font-size: var(--fs-small);
    color: var(--text-2);
  }
  .uc-hero__category {
    font-weight: 600;
    color: var(--text);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-size: var(--fs-micro);
  }
  .uc-hero__separator { color: var(--text-4); }
  .uc-hero__type {
    font-size: var(--fs-micro);
    color: var(--text-2);
  }

  .uc-hero__h {
    font-size: var(--fs-h1);
    line-height: 1;
    letter-spacing: -0.045em;
    color: var(--text);
    margin: 0;
  }

  .uc-hero__sub {
    color: var(--text-2);
    font-size: var(--fs-lead);
    max-width: 64ch;
    margin: 0;
    line-height: 1.55;
  }
</style>
