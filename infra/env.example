# Copy to repo-root `.env` (gitignored). Never commit real values.
#
# Namecheap API — Profile → Tools → Namecheap API Access
# Whitelist your public IP as ClientIp before calling the API.
NAMECHEAP_API_USER=
NAMECHEAP_API_KEY=
NAMECHEAP_USERNAME=
NAMECHEAP_CLIENT_IP=
# Set to "true" for api.sandbox.namecheap.com (test domains only).
NAMECHEAP_USE_SANDBOX=false

# Cloudflare API token (required for infra:email-routing catch-all; wrangler OAuth covers enable).
# Create at https://dash.cloudflare.com/profile/api-tokens with:
#   Zone:DNS:Edit, Zone:Read, Email Routing:Edit, Email Routing Rules:Edit, Workers Scripts:Edit
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=7ed31ecd01f2a97f6083b1c18da66779
